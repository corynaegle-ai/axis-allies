{
  "name": "axis-allies",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "build:shared": "npm --workspace shared run build",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "dev": "npm run build:shared && concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build:shared && npm --workspace server run build && npm --workspace client run build",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "country-flag-icons": "^1.6.16",
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0"
  }
}
